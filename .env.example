# LLM (use one). Model strings use Deep Agents `provider:model` format — https://docs.langchain.com/oss/python/deepagents/overview
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=openai
# Default for everyone who does *not* use BYOK: host pays via OPENAI_API_KEY / ANTHROPIC_API_KEY above.
# gpt-4o-mini and Claude Haiku are relatively low cost; there is no keyless OpenAI/Anthropic tier for production chat.
DEEPAGENTS_MODEL=openai:gpt-4o-mini
# BYOK (saved user keys): OpenAI calls use openai:gpt-4o-mini unless DEEPAGENTS_MODEL is set and starts with openai: (then that model).
# Anthropic BYOK uses DEEPAGENTS_MODEL if it starts with anthropic:, else ANTHROPIC_MODEL (optional), else anthropic:claude-3-5-haiku-20241022.

# Search (required for music discovery)
TAVILY_API_KEY=

# Spotify (optional; for playlists, library profile, and taste memory ingestion)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Redirect URI must match Spotify Developer Dashboard exactly.
# Local: loopback IP (Spotify blocks plain localhost for new apps).
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8013/auth/callback
# Production (Next.js /api/agent proxy — recommended): same host as the UI, e.g.
# SPOTIFY_REDIRECT_URI=https://your-app.vercel.app/api/agent/auth/callback
# Production (browser → API directly): https://your-api-host/auth/callback — see docs/DEPLOYMENT.md
FRONTEND_URL=http://127.0.0.1:3003
# Next `/api/agent/*` proxy target (no trailing slash). Repo-root `.env` is loaded by `apps/web/next.config.ts`; `apps/web/.env.local` overrides. Vercel: set in project env.
AGENT_API_URL=http://127.0.0.1:8013
# Browser origins allowed to call the API (comma-separated). Loaded automatically by FastAPI app.
CORS_ALLOW_ORIGINS=http://127.0.0.1:3003,http://localhost:3003
# Session cookie secret for API auth session
SESSION_SECRET=replace_me_with_random_secret
# Optional BYOK: encrypt per-user OpenAI/Anthropic keys in Supabase (see supabase/user_llm_keys.sql).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# USER_LLM_KEYS_FERNET_KEY=
# Production (HTTPS): SESSION_COOKIE_SECURE=1 ; often SESSION_SAME_SITE=lax or none (none needs Secure)
# SESSION_COOKIE_SECURE=1
# SESSION_SAME_SITE=lax
# Supabase (taste memory)
SUPABASE_URL=
# Required for backend ingest/retrieval + OAuth token storage.
SUPABASE_SERVICE_ROLE_KEY=
# Optional frontend/public vars
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Postgres checkpointer (recommended: Supabase Postgres connection string)
CHECKPOINT_DATABASE_URL=
# Optional alias if you prefer this naming
# SUPABASE_DB_URL=
# Tavily web search: leave MUSIC_SEARCH_INCLUDE_DOMAINS unset for open-web discovery (diverse sources).
# Set a comma-separated allowlist only if you want to restrict results (keep it short; Tavily best practices).
# Example curated preset (copy if you miss the old default): spotify.com,pitchfork.com,bandcamp.com,soundcloud.com,npr.org,rollingstone.com,billboard.com,reddit.com,rateyourmusic.com,allmusic.com,last.fm,musicboard.app,residentadvisor.net,stereogum.com,nme.com
# MUSIC_SEARCH_INCLUDE_DOMAINS=
# Optional: block low-signal domains (comma-separated)
# MUSIC_SEARCH_EXCLUDE_DOMAINS=

# DeepAgents is the default runtime.
# Skills: bundle repo skills/v1-lite-music/SKILL.md (StateBackend seed). Set 0 to disable.
# DEEPAGENTS_SKILLS=1
# Long-term memory: CompositeBackend /memories/ → LangGraph store (InMemoryStore in-process; dev only — use PostgresStore + per-user namespaces in prod).
# DEEPAGENTS_LT_MEMORY=0
# Human-in-the-loop (Deep Agents): pause before Spotify playlist/save/taste-ingest and before write_file/edit_file. Default on; uses MemorySaver when no CHECKPOINT_DATABASE_URL.
# https://docs.langchain.com/oss/python/deepagents/human-in-the-loop
# DEEPAGENTS_HITL=1
# Optional override (takes precedence when set): SPOTIFY_HITL=0 to disable HITL.
# Force LangGraph MemorySaver for thread checkpoints even if HITL is off (usually unset).
# LANGGRAPH_CHECKPOINTER=memory
# Background-load agent after API starts so first /chat is faster (set 0 to skip prewarm).
# PREWARM_AGENT=1
# Optional: max seconds for one POST /chat (JSON) agent run (default 300). Streaming /chat/stream is limited by the Next proxy (600s default for chat paths unless AGENT_API_FETCH_TIMEOUT_MS is set in apps/web).
# AGENT_TIMEOUT_SECONDS=300
# Per-HTTP-call timeout for the LLM when using init_chat_model (default 120). See Deep Agents customization / connection resilience.
# LLM_REQUEST_TIMEOUT_SECONDS=120
# LLM_MAX_RETRIES=4
# Disable bound model (use raw provider:model string only): DEEPAGENTS_MODEL_INIT=0
# Optional: emit per-chat timing logs in API terminal.
# CHAT_DEBUG_LOGS=1
# Production: leave unset so JSON errors stay generic (no exception text to clients). Dev-only:
# EXPOSE_INTERNAL_ERRORS=1
# Optional: ignore HTTP(S) proxy env vars for outbound LLM calls (useful if proxy returns 403).
# DISABLE_OUTBOUND_PROXY=1

# LangSmith tracing/evaluation (optional but recommended for debugging slow turns).
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=spotify-llm-dev