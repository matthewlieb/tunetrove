# Product title in the UI and browser tab (optional).
# NEXT_PUBLIC_APP_NAME=TempoTrove

# Server-only: where Next.js proxies /api/agent/* (FastAPI). Restart dev after changes.
AGENT_API_URL=http://127.0.0.1:8013

# Production (Vercel): set to your public FastAPI origin, e.g. https://spotify-llm-api.fly.dev
# AGENT_API_URL=https://your-api.example.com

# Optional: upstream fetch timeout in ms (default 600000 for POST /chat and /chat/stream only).
# Must be ≤ Vercel function maxDuration for the proxy route (see apps/web/vercel.json).
# AGENT_API_FETCH_TIMEOUT_MS=600000

# 1 = same-origin /api/agent proxy (default; best for OAuth cookies on phones). 0 = direct cross-origin.
NEXT_PUBLIC_USE_AGENT_PROXY=1

# Shown in UI + used when NEXT_PUBLIC_USE_AGENT_PROXY=0 — should match your FastAPI URL.
NEXT_PUBLIC_AGENT_API_BASE_URL=http://127.0.0.1:8013

# 0 = disable SSE and use POST /chat only. Default (unset) = stream via POST /chat/stream.
# NEXT_PUBLIC_CHAT_STREAM=0
